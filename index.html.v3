<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AniPlay Offline - Game Hub</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <div class="app">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <span class="logo-icon">🎮</span>
                    <h1>AniPlay</h1>
                </div>
            </div>

            <nav class="sidebar-nav">
                <button class="nav-item active" data-section="dashboard">
                    <span class="nav-icon">📊</span>
                    <span>Dashboard</span>
                </button>
                <button class="nav-item" data-section="games">
                    <span class="nav-icon">🕹️</span>
                    <span>All Games</span>
                </button>
                <button class="nav-item" data-section="upload">
                    <span class="nav-icon">📤</span>
                    <span>Upload Game</span>
                </button>
                <button class="nav-item" data-section="favorites">
                    <span class="nav-icon">❤️</span>
                    <span>Favorites</span>
                </button>
                <button class="nav-item" data-section="settings">
                    <span class="nav-icon">⚙️</span>
                    <span>Settings</span>
                </button>
            </nav>

            <div class="sidebar-footer">
                <p>v1.0 | Offline Mode</p>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <header class="header">
                <div class="header-left">
                    <button class="menu-toggle" id="menuToggle">☰</button>
                    <div class="search-box">
                        <input type="text" id="searchInput" placeholder="Search games...">
                        <span class="search-icon">🔍</span>
                    </div>
                </div>

                <div class="header-right">
                    <button class="btn-theme" id="themeToggle">🌙</button>
                    <div class="profile">
                        <span class="profile-initial">A</span>
                    </div>
                </div>
            </header>

            <!-- Content Sections -->
            <div class="content">
                <!-- Dashboard Section -->
                <section id="dashboard" class="section active">
                    <div class="section-header">
                        <h2>Welcome to AniPlay Offline</h2>
                        <p>1000+ games available offline</p>
                    </div>

                    <div class="dashboard-grid">
                        <!-- Stats Cards -->
                        <div class="stat-card">
                            <div class="stat-icon">🎮</div>
                            <div class="stat-info">
                                <h3>Games Played</h3>
                                <p class="stat-value" id="statGamesPlayed">0</p>
                            </div>
                        </div>

                        <div class="stat-card">
                            <div class="stat-icon">⏱️</div>
                            <div class="stat-info">
                                <h3>Playtime</h3>
                                <p class="stat-value" id="statPlaytime">0h</p>
                            </div>
                        </div>

                        <div class="stat-card">
                            <div class="stat-icon">⭐</div>
                            <div class="stat-info">
                                <h3>Achievements</h3>
                                <p class="stat-value" id="statAchievements">0</p>
                            </div>
                        </div>

                        <div class="stat-card">
                            <div class="stat-icon">📦</div>
                            <div class="stat-info">
                                <h3>Downloaded</h3>
                                <p class="stat-value" id="statDownloaded">1000+</p>
                            </div>
                        </div>
                    </div>

                    <!-- Featured Games -->
                    <div class="featured-section">
                        <h3>Featured Games</h3>
                        <div class="featured-grid" id="featuredGames">
                            <!-- Populated by JS -->
                        </div>
                    </div>

                    <!-- Recent Games -->
                    <div class="recent-section">
                        <h3>Recently Played</h3>
                        <div class="games-list" id="recentGames">
                            <!-- Populated by JS -->
                        </div>
                    </div>
                </section>

                <!-- Games Section -->
                <section id="games" class="section">
                    <div class="section-header">
                        <h2>Game Library</h2>
                        <div class="filter-buttons">
                            <button class="filter-btn active" data-filter="all">All Games</button>
                            <button class="filter-btn" data-filter="shinobi">⚔️ Shinobi</button>
                            <button class="filter-btn" data-filter="isekai">🗺️ Isekai</button>
                            <button class="filter-btn" data-filter="kawaii">🎀 Kawaii</button>
                            <button class="filter-btn" data-filter="mecha">🤖 Mecha</button>
                            <button class="filter-btn" data-filter="spirit">👻 Spirit</button>
                        </div>
                    </div>

                    <div class="games-grid" id="gamesGrid">
                        <!-- Populated by JS -->
                    </div>
                </section>

                <!-- Upload Section -->
                <section id="upload" class="section">
                    <div class="section-header">
                        <h2>Upload Custom Game</h2>
                        <p>Add your own game to the library</p>
                    </div>

                    <div class="upload-container">
                        <div class="upload-form">
                            <div class="form-group">
                                <label>Game Title *</label>
                                <input type="text" id="gameTitle" placeholder="Enter game title" class="form-input">
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label>Category *</label>
                                    <select id="gameCategory" class="form-input">
                                        <option value="">Select Category</option>
                                        <option value="shinobi">⚔️ Shinobi Arc</option>
                                        <option value="isekai">🗺️ Isekai Arc</option>
                                        <option value="kawaii">🎀 Kawaii Arc</option>
                                        <option value="mecha">🤖 Mecha Arc</option>
                                        <option value="spirit">👻 Spirit Arc</option>
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label>Rating *</label>
                                    <input type="number" id="gameRating" min="1" max="5" step="0.1" placeholder="4.5" class="form-input">
                                </div>
                            </div>

                            <div class="form-group">
                                <label>Description *</label>
                                <textarea id="gameDesc" placeholder="Describe your game..." class="form-input" rows="4"></textarea>
                            </div>

                            <div class="form-group">
                                <label>Game Cover Image *</label>
                                <div class="image-upload">
                                    <input type="file" id="gameImage" accept="image/*" class="file-input">
                                    <div class="upload-area" id="uploadArea">
                                        <span class="upload-icon">📸</span>
                                        <p>Drag & Drop or Click to Upload</p>
                                        <span class="file-hint">PNG, JPG, GIF up to 5MB</span>
                                    </div>
                                    <div class="image-preview" id="imagePreview">
                                        <!-- Image preview will appear here -->
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label>Game URL (Optional)</label>
                                <input type="url" id="gameUrl" placeholder="https://example.com/game" class="form-input">
                            </div>

                            <div class="form-actions">
                                <button class="btn btn-primary" id="uploadBtn">✓ Upload Game</button>
                                <button class="btn btn-secondary" id="resetBtn">↻ Reset Form</button>
                            </div>
                        </div>

                        <div class="upload-preview">
                            <h3>Preview</h3>
                            <div class="preview-card" id="previewCard">
                                <div class="preview-image">📸</div>
                                <h4>Game Title</h4>
                                <p class="preview-category">Category</p>
                                <p class="preview-desc">Description will appear here...</p>
                                <div class="preview-rating">⭐ 4.5</div>
                            </div>
                        </div>
                    </div>

                    <!-- Uploaded Games List -->
                    <div class="uploaded-games">
                        <h3>Your Uploaded Games</h3>
                        <div class="uploaded-list" id="uploadedList">
                            <p class="empty-state">No games uploaded yet</p>
                        </div>
                    </div>
                </section>

                <!-- Favorites Section -->
                <section id="favorites" class="section">
                    <div class="section-header">
                        <h2>Favorite Games</h2>
                        <p>Your saved games</p>
                    </div>

                    <div class="games-grid" id="favoritesGrid">
                        <p class="empty-state">No favorites yet. Add some games to your favorites!</p>
                    </div>
                </section>

                <!-- Settings Section -->
                <section id="settings" class="section">
                    <div class="section-header">
                        <h2>Settings</h2>
                    </div>

                    <div class="settings-container">
                        <div class="settings-group">
                            <h3>Display</h3>
                            <div class="setting-item">
                                <label>Dark Mode</label>
                                <input type="checkbox" class="toggle" id="darkModeToggle">
                            </div>
                        </div>

                        <div class="settings-group">
                            <h3>Storage</h3>
                            <div class="setting-item">
                                <label>Storage Used</label>
                                <p id="storageUsed">Calculating...</p>
                            </div>
                            <button class="btn btn-secondary" id="clearDataBtn">Clear All Data</button>
                        </div>

                        <div class="settings-group">
                            <h3>About</h3>
                            <p>AniPlay Offline v1.0</p>
                            <p>1000+ Games | Zero Internet Required</p>
                        </div>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <!-- Modal for Game Details -->
    <div class="modal" id="gameModal">
        <div class="modal-content">
            <button class="modal-close">&times;</button>
            <div class="modal-body">
                <div class="modal-image" id="modalImage">📸</div>
                <div class="modal-info">
                    <h2 id="modalTitle">Game Title</h2>
                    <div class="modal-meta">
                        <span class="badge" id="modalCategory">Category</span>
                        <span class="rating" id="modalRating">⭐ 4.5</span>
                    </div>
                    <p id="modalDesc">Game description...</p>
                    <div class="modal-actions">
                        <button class="btn btn-primary" id="playBtn">▶ Play</button>
                        <button class="btn btn-secondary" id="favoriteBtn">❤ Favorite</button>
                        <button class="btn btn-secondary" id="shareBtn">📤 Share</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div class="toast" id="toast"></div>

    <script src="js/app.js"></script>
</body>
</html>
